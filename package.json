{
  "name": "aquarium-mobile",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "start": "expo start --clear",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "postinstall": "node scripts/patch-expo-keep-awake.cjs",
    "test:firestore": "node scripts/run-firestore-rules-tests.cjs",
    "firestore:deploy:rules": "firebase deploy --only firestore:rules --project my-aquarium-assistant",
    "storage:deploy:rules": "firebase deploy --only storage --project my-aquarium-assistant",
    "sync:catalog:dry-run": "node scripts/sync-fish-plant-catalog.cjs --dry-run",
    "sync:catalog": "node scripts/sync-fish-plant-catalog.cjs",
    "sync:catalog:prune": "node scripts/sync-fish-plant-catalog.cjs --prune --confirm-prune=I_UNDERSTAND_THIS_DELETES_DATA",
    "sync:disease:dry-run": "node scripts/sync-fish-disease-catalog.cjs --dry-run",
    "sync:disease": "node scripts/sync-fish-disease-catalog.cjs",
    "sync:disease:prune": "node scripts/sync-fish-disease-catalog.cjs --prune --confirm-prune=I_UNDERSTAND_THIS_DELETES_DATA",
    "sync:plant-disease:dry-run": "node scripts/sync-plant-disease-catalog.cjs --dry-run",
    "sync:plant-disease": "node scripts/sync-plant-disease-catalog.cjs",
    "sync:plant-disease:prune": "node scripts/sync-plant-disease-catalog.cjs --prune --confirm-prune=I_UNDERSTAND_THIS_DELETES_DATA",
    "sync:algae:dry-run": "node scripts/sync-algae-catalog.cjs --dry-run",
    "sync:algae": "node scripts/sync-algae-catalog.cjs",
    "sync:algae:prune": "node scripts/sync-algae-catalog.cjs --prune --confirm-prune=I_UNDERSTAND_THIS_DELETES_DATA",
    "release:smoke:gate": "node scripts/release-smoke-gate.cjs --checklist docs/release-smoke-checklist.md --result docs/release-smoke-result.md --outDir release-smoke-artifacts",
    "sanitize:legacy:dry-run": "node scripts/sanitize-legacy-firestore-docs.cjs --dry-run",
    "sanitize:legacy": "node scripts/sanitize-legacy-firestore-docs.cjs",
    "sync:equipment:filter-types": "node scripts/sync-equipment-filter-types.cjs",
    "sync:equipment:catalog": "node scripts/sync-equipment-catalog.cjs",
    "release:preflight": "node scripts/release-candidate-preflight.cjs",
    "billing:webhook:start": "node scripts/subscription-webhook-server.cjs",
    "billing:sandbox:audit": "node scripts/billing-sandbox-audit.cjs",
    "billing:subscriptions:report": "node scripts/report-user-subscriptions.cjs",
    "test:subscription:webhook": "node --test tests/subscriptionWebhookSync.test.cjs",
    "test:subscription:gating": "node --test tests/aiSubscriptionGating.test.cjs",
    "ai:backend:start": "node scripts/ai-backend-server.cjs",
    "test:ai:backend": "node --test tests/aiContextBuilder.test.cjs tests/aiBackendEndpoints.test.cjs",
    "ai:release:audit": "node scripts/ai-release-config-audit.cjs"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/drawer": "^7.9.9",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.2.2",
    "expo": "~54.0.33",
    "expo-auth-session": "~7.0.10",
    "expo-constants": "~18.0.13",
    "expo-image-picker": "~17.0.11",
    "expo-linking": "~8.0.11",
    "expo-notifications": "~0.32.17",
    "expo-router": "~6.0.23",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.10",
    "firebase": "^12.12.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-purchases": "^9.5.4",
    "react-native-reanimated": "4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1",
    "firebase-admin": "^13.9.0"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.0",
    "@types/react": "~19.1.0",
    "@types/react-native": "^0.72.8",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "firebase-tools": "^15.17.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
