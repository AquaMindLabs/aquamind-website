EXPO_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
EXPO_PUBLIC_FIREBASE_APP_ID=your_firebase_app_id

# Google OAuth:
# ANDROID client ID = OAuth 2.0 Client ID typu "Android" (package: com.myaquarium.assistant + poprawny SHA-1/SHA-256)
# IOS client ID = OAuth 2.0 Client ID typu "iOS" (bundle: com.myaquarium.assistant)
# WEB client ID = OAuth 2.0 Client ID typu "Web application" (ten ID jest wymagany do ID tokenu dla Firebase)
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=your_google_android_client_id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_ANDROID_DEBUG_CLIENT_ID=your_google_android_debug_client_id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_ANDROID_RELEASE_CLIENT_ID=your_google_android_release_client_id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your_google_ios_client_id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your_google_web_client_id.apps.googleusercontent.com

# RevenueCat billing
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=
EXPO_PUBLIC_REVENUECAT_ENTITLEMENT_ID=

EXPO_PUBLIC_SUBSCRIPTION_PREMIUM_IOS_PRODUCT_ID=
EXPO_PUBLIC_SUBSCRIPTION_PREMIUM_ANDROID_PRODUCT_ID=
# Backward-compatible Android aliases used by older release configs:
EXPO_PUBLIC_SUBSCRIPTION_PLUS_ANDROID_PRODUCT_ID=
EXPO_PUBLIC_SUBSCRIPTION_PRO_IOS_PRODUCT_ID=
EXPO_PUBLIC_SUBSCRIPTION_PRO_ANDROID_PRODUCT_ID=
EXPO_PUBLIC_SUBSCRIPTION_AI_PRO_ANDROID_PRODUCT_ID=

EXPO_PUBLIC_ENABLE_LOCAL_PLAN_SIMULATION=false
EXPO_PUBLIC_ENABLE_ADMIN_PLAN_OVERRIDE=false

# Backend webhook sync (RevenueCat -> userSubscriptions)
FIREBASE_PROJECT_ID=your-project-id
SUBSCRIPTION_WEBHOOK_PORT=8787
SUBSCRIPTION_WEBHOOK_PATH=/webhooks/revenuecat
SUBSCRIPTION_WEBHOOK_SECRET=change_me
SUBSCRIPTION_PLAN_VERSION=4

# AI backend
AI_BACKEND_PORT=8790
AI_PROVIDER_TIMEOUT_MS=45000
AI_TEXT_MONTHLY_LIMIT=100
AI_VISION_MONTHLY_LIMIT=20
AI_PROVIDER_NAME=rule_based
# Dev lokalny: http://127.0.0.1:8790 albo http://<LAN_IP>:8790
# Produkcja: publiczny HTTPS endpoint backendu, np. https://ai-backend.example.com
EXPO_PUBLIC_AI_BACKEND_URL=http://127.0.0.1:8790

# Enable real provider (optional):
# AI_PROVIDER_NAME=openai
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-5-mini
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MAX_OUTPUT_TOKENS=2400
